APP_NAME=Team Task Manager
DEBUG=True
VERSION=1.0.0

# Database (PostgreSQL with asyncpg driver)
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Format: postgresql+asyncpg://<username>:<password>@<host>:<port>/<db_name>
# Note: if your password contains special characters (e.g. `@`), URL-encode it (e.g. `@` -> `%40`).
DATABASE_URL=postgresql+asyncpg://USERNAME:PASSWORD@HOST:5432/DBNAME

# Redis
REDIS_URL=redis://HOST:6379/0

# JWT
JWT_SECRET=CHANGE_ME
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limiting
LOGIN_RATE_LIMIT=5/minute
